{
  "name": "connectlan",
  "version": "1.0.0",
  "description": "Finder-inspired LAN file transfer application",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js --no-tls",
    "build": "pkg .",
    "build:mac-arm64": "pkg . --target node22-macos-arm64 --out-path dist",
    "build:mac-x64": "pkg . --target node22-macos-x64 --out-path dist",
    "build:win": "pkg . --target node22-win-x64 --out-path dist",
    "build:linux": "pkg . --target node22-linux-x64 --out-path dist"
  },
  "pkg": {
    "assets": ["public/**/*"],
    "targets": [
      "node22-macos-arm64",
      "node22-macos-x64",
      "node22-win-x64",
      "node22-linux-x64"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "lan",
    "file-transfer",
    "local-network"
  ],
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1",
    "express": "^4.21.2",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "selfsigned": "^5.5.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1"
  }
}
